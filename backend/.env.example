# Backend server port
PORT=4000

# Supabase Credentials
# Get these from your Supabase Dashboard: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_anon_key

# Meilisearch Credentials
# For Meilisearch Cloud get keys here: https://cloud.meilisearch.com/
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_API_KEY=masterKey

# GitHub OAuth Credentials
# Create a new OAuth App here: https://github.com/settings/developers
# (Make sure to set Authorization callback URL to: http://localhost:4000/api/auth/cli/callback)
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# GitHub Webhook Secret
# This is a secret string you create. You will also put this in your GitHub Repo -> Settings -> Webhooks
GITHUB_WEBHOOK_SECRET=my-secret
